# --- Database (PostgreSQL) ---
# Railway: use the DATABASE_URL from your Postgres plugin (often includes ?sslmode=require).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# If you use a connection pooler with transaction mode (PgBouncer), add a direct URL for migrations:
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Then add to prisma/schema.prisma: directUrl = env("DIRECT_DATABASE_URL")

# --- AI / image APIs ---
ANTHROPIC_API_KEY=
KIE_API_KEY=

# Optional Kie endpoint overrides (defaults: api.kie.ai / kieai.redpandaai.co)
# KIE_API_BASE=https://api.kie.ai
# KIE_UPLOAD_BASE=https://kieai.redpandaai.co

# Optional Anthropic tuning (see src/lib/anthropic.ts)
# ANTHROPIC_FUNDRAISER_BATCH_MODEL=
# ANTHROPIC_FUNDRAISER_BATCH_THINKING=true

# --- Next.js / deployment ---
# PORT is set automatically on Railway.
# For standalone (`npm start` → node .next/standalone/server.js), some platforms need:
# HOSTNAME=0.0.0.0
# If Server Actions fail with origin errors behind multiple public URLs, set at build time:
# SERVER_ACTIONS_ALLOWED_ORIGINS=https://your-app.up.railway.app,https://custom-domain.com

NODE_ENV=production
